{
  "name": "api-productos",
  "version": "1.0.0",
  "description": "API básica de productos para demostración de pipelines",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --reporters=default --reporters=jest-junit",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:report": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "jest": {
    "testPathIgnorePatterns": ["/node_modules/", "/tests/e2e/"]
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.4",
    "@playwright/test": "^1.44.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.29.0"
  }
}
